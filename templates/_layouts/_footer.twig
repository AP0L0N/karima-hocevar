<footer>

    {% if entry is not defined or (entry is defined and entry.section.handle not in ['events', 'newsletter']) %}
    <div class="stay-up-to-date">
        <div class="container">
            <div class="stay-up-to-date__wrapper">
                <h2>
                    <span>{{ "Stay updated!" | t }}</span>
                    <a href="/newsletter">
                        <span>{{ "Sign up for newsletter" | t }}</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8"/></svg>
                    </a>
                </h2>
            </div>
        </div>
    </div>
    {% endif %}

    <div class="footer">
        <div class="container">
            <div class="footer__wrapper">
                <div class="footer__wrapper__content">
                    
                    <div class="footer__wrapper__content__logo d-lg-none">
                        <img src="/assets/svg/logo.svg" alt="">
                    </div>

                    <div class="footer__wrapper__content__menu">
                        <ul>
                            <li><a href="/about-me">{{ "About me" | t }}</a></li>
                            <li><a href="/resonant-touch">{{ "Resonant Touch" | t }}</a></li>
                            <li><a href="/individual-sessions">{{ "Individual Sessions" | t }}</a></li>
                            <li><a href="/narm">{{ "NARM" | t }}</a></li>
                            <li><a href="/inspirations">{{ "Inspirations" | t }}</a></li>
                            <li><a href="/newsletter">{{ "Newsletter" | t }}</a></li>
                        </ul>
                    </div>
                    <div class="footer__wrapper__content__contact">
                        <h3>{{ "Contact" | t }}</h3>
                        <div class="footer__wrapper__content__contact__item">
                            <a href="mailto:info@karima-hocevar.com">
                                <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 19 19" fill="none">
                                    <path d="M2.37498 2.375H16.625C17.0622 2.375 17.4166 2.72944 17.4166 3.16667V15.8333C17.4166 16.2706 17.0622 16.625 16.625 16.625H2.37498C1.93775 16.625 1.58331 16.2706 1.58331 15.8333V3.16667C1.58331 2.72944 1.93775 2.375 2.37498 2.375ZM15.8333 5.73008L9.55698 11.3509L3.16665 5.71267V15.0417H15.8333V5.73008ZM3.57119 3.95833L9.54827 9.23242L15.4391 3.95833H3.57119Z" fill="#C58FAC"/>
                                </svg>
                                <span>info@karima-hocevar.com</span>
                            </a>
                        </div>
                        <div class="footer__wrapper__content__contact__item">
                               
                                </svg>
                            </a>
                        </div>
                        <div class="footer__wrapper__content__contact__item">
                           
                                   
                            </a>
                        </div>
                    </div>
                    
                    <div class="footer__wrapper__content__logo d-none d-lg-block">
                        <img src="/assets/svg/logo.svg" alt="">
                    </div>
                </div>
                <div class="footer__wrapper__bottom">
                    <div class="footer__wrapper__bottom__links">
                        <a href="/terms-of-use">{{ "Terms of use" | t }}</a>
                        <a href="/privacy-policy">{{ "Privacy policy" | t }}</a>
                    </div>
                    <div class="footer__wrapper__bottom__copyright">
                        <p>© {{ now|date('Y') }} © Karima Valentina Hočevar</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</footer>